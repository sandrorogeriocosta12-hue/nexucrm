# Security Environment Configuration for Vexus Service
# Copy this file to .env.security and fill in your actual values

# 🔒 BASIC SECURITY
SECRET_KEY=your-ultra-secret-key-here-at-least-32-characters-long
DEBUG=false
ENVIRONMENT=production

# 🚦 RATE LIMITING
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000
RATE_LIMIT_REQUESTS_PER_DAY=10000

# 🔐 SECRETS MANAGEMENT
SECRETS_MANAGER_TYPE=aws
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# HashiCorp Vault (alternative to AWS)
# SECRETS_MANAGER_TYPE=hashicorp
# VAULT_URL=https://vault.example.com:8200
# VAULT_TOKEN=hvs.your-vault-token-here

# Azure Key Vault (alternative)
# SECRETS_MANAGER_TYPE=azure
# AZURE_VAULT_URL=https://your-vault.vault.azure.net/

# Google Secret Manager (alternative)
# SECRETS_MANAGER_TYPE=google
# GOOGLE_PROJECT_ID=your-project-id

# Local development (not for production)
# SECRETS_MANAGER_TYPE=local
# SECRETS_FILE=.env.secrets

# 📊 LOGGING
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_RETENTION_DAYS=30

# 🗄️ DATABASE SECRETS (loaded from secrets manager)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vexus_prod
DB_USER=vexus_user
DB_PASSWORD=your-secure-db-password

# 🔑 JWT SECRETS
JWT_SECRET=your-jwt-secret-here-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# 📧 EMAIL SECRETS
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# 🔐 API KEYS
API_KEY_1=your-api-key-1
API_KEY_2=your-api-key-2

# 🔒 ENCRYPTION
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# 🚀 REDIS
REDIS_PASSWORD=your-secure-redis-password

# 🔒 SSL CERTIFICATES (for production)
SSL_CERT_PATH=/path/to/ssl/server.crt
SSL_KEY_PATH=/path/to/ssl/server.key