# ================================
# VEXUS SERVICE - PRODUCTION CONFIG
# ================================
# NÃO FAZER COMMIT DESTE ARQUIVO!
# Manter .env.production em .gitignore
# Usar GitHub Secrets para produção

# ================================
# AMBIENTE
# ================================
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=False
VERSION=1.0.0

# ================================
# DATABASE
# ================================
# Exemplo: postgresql://user:password@host.digitalocean.com:25060/vexus_crm
DATABASE_URL=postgresql://user:password@db.example.com:5432/vexus_crm
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ================================
# REDIS/CACHE
# ================================
# Exemplo: redis://default:password@host:25061
REDIS_URL=redis://user:password@redis.example.com:6379/0
REDIS_SSL=false

# ================================
# IA & AGENTS (OBRIGATÓRIO)
# ================================
# Obter em: https://platform.openai.com/api/keys
# Formato: sk-proj-xxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-proj-SEU_API_KEY_AQUI
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7

# ================================
# WHATSAPP OMNICHANNEL (OBRIGATÓRIO)
# ================================
# Obter em: https://business.facebook.com
WHATSAPP_BUSINESS_API_KEY=Bearer SEU_TOKEN_AQUI
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_WEBHOOK_TOKEN=SEU_WEBHOOK_TOKEN_AQUI
WHATSAPP_VERIFY_TOKEN=SEU_VERIFY_TOKEN_AQUI

# ================================
# EMAIL - SendGrid (OPCIONAL)
# ================================
# Obter em: https://sendgrid.com/go/api-key-management
SENDGRID_API_KEY=SG.SEU_API_KEY_AQUI
SENDGRID_FROM_EMAIL=noreply@vexus.com.br
SENDGRID_FROM_NAME=Vexus CRM

# ================================
# SMS - Twilio (OPCIONAL)
# ================================
# Obter em: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+5511999999999

# ================================
# INSTAGRAM/META (OPCIONAL)
# ================================
# Obter em: https://developers.facebook.com
META_ACCESS_TOKEN=SEU_ACCESS_TOKEN_AQUI
META_BUSINESS_ACCOUNT_ID=123456789
META_API_VERSION=v18.0

# ================================
# TELEGRAM (OPCIONAL)
# ================================
TELEGRAM_BOT_TOKEN=SEU_BOT_TOKEN_AQUI
TELEGRAM_WEBHOOK_URL=https://app.vexus.com.br/api/messages/webhook/telegram

# ================================
# SEGURANÇA (GERAR VALORES ALEATÓRIOS!)
# ================================
# Gerar com: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GERAR_VALOR_ALEATORIO_MIN_32_CHARS
JWT_SECRET=GERAR_VALOR_ALEATORIO_MIN_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
CORS_ALLOW_CREDENTIALS=true

# ================================
# API SETTINGS
# ================================
ALLOWED_ORIGINS=https://app.vexus.com.br,https://vexus.com.br,https://admin.vexus.com.br
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=300

# ================================
# AUTENTICAÇÃO
# ================================
ENABLE_OAUTH_GOOGLE=true
ENABLE_OAUTH_GITHUB=false
OAUTH_GOOGLE_CLIENT_ID=SEU_CLIENT_ID_AQUI
OAUTH_GOOGLE_CLIENT_SECRET=SEU_CLIENT_SECRET_AQUI

# ================================
# STRIPE - Pagamentos (OPCIONAL)
# ================================
# Obter em: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_live_XXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXX

# ================================
# AWS S3 - Storage (OPCIONAL)
# ================================
# Para upload de documentos/arquivos
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXX
AWS_REGION=us-east-1
S3_BUCKET=vexus-crm-uploads
S3_BUCKET_REGION=us-east-1

# ================================
# MONITORING & ERROR TRACKING
# ================================
# Sentry (erro tracking)
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# New Relic (APM)
NEW_RELIC_LICENSE_KEY=XXXXXXXXXXXXX
NEW_RELIC_APP_NAME=vexus-crm-prod

# DataDog (métricas)
DATADOG_API_KEY=XXXXXXXXXXXXX
DATADOG_APP_KEY=XXXXXXXXXXXXX

# ================================
# LOGGING
# ================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_TO_STDOUT=true
LOG_TO_FILE=false

# ================================
# RATE LIMITING
# ================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=5000

# ================================
# CACHE SETTINGS
# ================================
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# ================================
# EMAIL VERIFICATION
# ================================
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_TOKEN_EXPIRY=3600

# ================================
# OPTIONAL: BACKGROUND JOBS
# ================================
CELERY_BROKER_URL=redis://user:password@redis.example.com:6379/1
CELERY_RESULT_BACKEND=redis://user:password@redis.example.com:6379/2
CELERY_ENABLE_UTC=true

# ================================
# FEATURE FLAGS
# ================================
FEATURE_AI_AGENTS=true
FEATURE_OMNICHANNEL=true
FEATURE_PIPELINE_VISUAL=true
FEATURE_FLOW_BUILDER=true
FEATURE_ANALYTICS=true
FEATURE_PAYMENTS=false

# ================================
# DOMAIN & URLs
# ================================
DOMAIN=vexus.com.br
FRONTEND_URL=https://app.vexus.com.br
API_URL=https://api.vexus.com.br
ADMIN_URL=https://admin.vexus.com.br

# ================================
# SSL/TLS
# ================================
SSL_ENABLED=true
SSL_REDIRECT=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true

# ================================
# BACKUP & DISASTER RECOVERY
# ================================
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE=s3://vexus-backups

# ================================
# HTTPS & DOMAIN
# ================================
DOMAIN=seu-dominio.com
HTTPS=true
SSL_CERT_PATH=/etc/letsencrypt/live/seu-dominio.com/fullchain.pem

# ================================
# EMAIL SERVICE (Resend > SendGrid > SMTP)
# ================================
# Option 1: Resend (recommended, modern)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_SEU_API_KEY_AQUI

# Option 2: SendGrid
# SENDGRID_API_KEY=SG.SEU_API_KEY_AQUI

# Option 3: SMTP (Gmail, custom mail server)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-app-aqui

EMAIL_FROM=noreply@seu-dominio.com
EMAIL_FROM_NAME=Vexus CRM

# ================================
# STRIPE PAYMENTS
# ================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_SEU_SECRET_KEY_AQUI
STRIPE_PUBLISHABLE_KEY=pk_test_SEU_PUBLIC_KEY_AQUI
STRIPE_WEBHOOK_SECRET=whsec_SEU_WEBHOOK_SECRET_AQUI

# Stripe product/price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_STARTER=price_1234567890
STRIPE_PRICE_PROFESSIONAL=price_0987654321
STRIPE_PRICE_BUSINESS=price_5555555555

# ================================
# SENTRY ERROR TRACKING
# ================================
# Get from: https://sentry.io/signup/
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ================================
# MULTI-TENANT & AUTHENTICATION
# ================================
# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=1
INVITE_TOKEN_EXPIRE_DAYS=7

# ================================
# GDPR & COMPLIANCE
# ================================
GDPR_ENABLED=true
DATA_RETENTION_DAYS=365

# ================================
# PRODUÇÃO - NOVOS COMPONENTES
# ================================

# EMAIL TRANSACIONAL (novo)
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_PRODUCTION=noreply@seu-dominio.com

# PAGAMENTOS - STRIPE (novo)
STRIPE_SECRET_KEY=sk_live_
STRIPE_PUBLISHABLE_KEY=pk_live_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_STARTER=price_
STRIPE_PRICE_PROFESSIONAL=price_
STRIPE_PRICE_BUSINESS=price_

# MONITORAMENTO - SENTRY (novo)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# MULTI-TENANT (novo)
ENABLE_MULTI_TENANT=true
DOMAIN=seu-dominio.com

# BACKUP (novo)
BACKUP_RETENTION_DAYS=7
POSTGRES_USER=vexus_user
POSTGRES_PASSWORD=
POSTGRES_DB=vexus_db

# SSL/CERTBOT (novo)
SSL_DOMAIN=seu-dominio.com
SSL_EMAIL=admin@seu-dominio.com

