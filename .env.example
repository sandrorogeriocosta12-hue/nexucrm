# ============================================================================
# 🔐 NEXUS CRM - PROFESSIONAL PRODUCTION CONFIGURATION
# Copy this file to .env and fill in your actual values
# ============================================================================

# ============================================================================
# 🚀 APPLICATION & SERVER
# ============================================================================
APP_NAME=Nexus CRM
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false

# ============================================================================
# 🔌 DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://vexus_user:secure_password@localhost:5432/vexus_crm
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=3600
SQLALCHEMY_ECHO=false

# ============================================================================
# 🔐 SECURITY
# ============================================================================
SECRET_KEY=your-very-secure-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this-too
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ============================================================================
# 📧 EMAIL CONFIGURATION
# ============================================================================
# Option 1: Gmail with App Password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@nexuscrm.tech
FROM_NAME=Nexus CRM

# Option 2: SendGrid (comment out gmail above)
# SMTP_SERVER=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.your_sendgrid_api_key

# Option 3: AWS SES
# SMTP_SERVER=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your-ses-user
# SMTP_PASSWORD=your-ses-password

# ============================================================================
# 🔄 REDIS for caching and sessions
# ============================================================================
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# 🌐 CORS & Security Headers
# ============================================================================
CORS_ORIGINS=https://nexuscrm.tech,https://www.nexuscrm.tech,https://app.nexuscrm.tech,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
ALLOWED_ORIGINS=https://nexuscrm.tech,https://www.nexuscrm.tech,https://app.nexuscrm.tech

# ============================================================================
# 📊 MONITORING & ERROR TRACKING
# ============================================================================
# Sentry (Error tracking & performance monitoring)
SENTRY_DSN=https://your-key@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Datadog (APM - Application Performance Monitoring)
# DD_API_KEY=your_datadog_api_key
# DD_SITE=datadoghq.com

# ============================================================================
# 📈 RATE LIMITING
# ============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# 📁 FILE UPLOAD
# ============================================================================
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# ============================================================================
# 🤖 AI & LLM SERVICES
# ============================================================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1000

# ============================================================================
# 📱 EXTERNAL INTEGRATIONS
# ============================================================================

# WhatsApp (Twilio)
WHATSAPP_BUSINESS_API_KEY=your-whatsapp-api-key
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=+1234567890

# Google OAuth
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret

# Stripe (if accepting payments)
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_PUBLIC_KEY=pk_live_your_key

# ============================================================================
# 🗄️ BACKUP & STORAGE
# ============================================================================
BACKUP_PATH=/data/backups
BACKUP_RETENTION_DAYS=30

# AWS S3 (optional cloud backup)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=nexuscrm-backups
AWS_REGION=us-east-1

# ============================================================================
# 📝 LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/nexuscrm/app.log

# ============================================================================
# 🎯 FEATURE FLAGS
# ============================================================================
ENABLE_2FA=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_ANALYTICS=true
ENABLE_API_DOCS=true

# ============================================================================
# 🌍 URLS
# ============================================================================
APP_URL=https://app.nexuscrm.tech
API_URL=https://api.nexuscrm.tech
FRONTEND_URL=https://nexuscrm.tech

# ============================================================================
# ⏱️ TIMEOUTS & LIMITS
# ============================================================================
REQUEST_TIMEOUT=30
SESSION_TIMEOUT=3600

# ============================================================================
# 📞 NOTIFICATIONS & ALERTS
# ============================================================================
ADMIN_EMAIL=admin@nexuscrm.tech
SUPPORT_EMAIL=support@nexuscrm.tech
ERROR_ALERT_EMAIL=alerts@nexuscrm.tech
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# 🔐 CLOUDFLARE & CDN
# ============================================================================
CLOUDFLARE_API_KEY=your_cloudflare_api_key
CLOUDFLARE_ZONE_ID=your_zone_id

# ============================================================================
# 🧪 TESTING
# ============================================================================
TESTING=false
TEST_DATABASE_URL=postgresql://test:test@localhost:5432/nexuscrm_test
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_VERSION=v17.0

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (Email)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Meta/Facebook (Ads, Instagram)
META_ACCESS_TOKEN=your-meta-access-token
META_BUSINESS_ACCOUNT_ID=your-business-account-id

# Stripe (Payments)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
SENTRY_DSN=your-sentry-dsn

# Logging
LOG_LEVEL=INFO

# Backup
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# Feature Flags
ENABLE_WHATSAPP=true
ENABLE_EMAIL=true
ENABLE_ANALYTICS=true
ENABLE_AI_AGENTS=true

# Cache
CACHE_ENABLED=true
CACHE_TTL=300