# 🔐 Nexus CRM - Exemplo de Configuração (.env)
# Salve este arquivo como .env no diretório raiz
# Substitua os valores XXXXX pelos seus tokens reais

# ═══════════════════════════════════════════════════════════════════════
# 🔐 WHATSAPP BUSINESS API
# Obter em: https://developers.facebook.com/
# ═══════════════════════════════════════════════════════════════════════
WHATSAPP_ACCESS_TOKEN=EAAU...sua-token-aqui...XXXXX
WHATSAPP_PHONE_ID=1234567890
WHATSAPP_BUSINESS_ID=9876543210

# ═══════════════════════════════════════════════════════════════════════
# 🤖 TELEGRAM BOT API
# Obter em: Telegram com @BotFather
# ═══════════════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...sua-token-aqui...XXXXX

# ═══════════════════════════════════════════════════════════════════════
# 📧 SENDGRID EMAIL API
# Obter em: https://sendgrid.com/
# ═══════════════════════════════════════════════════════════════════════
SENDGRID_API_KEY=SG.sk_live...sua-key-aqui...XXXXX
EMAIL_FROM=noreply@nexuscrm.tech

# ═══════════════════════════════════════════════════════════════════════
# 📸 META BUSINESS (Instagram/Facebook)
# Obter em: facebook.com/business/tools
# ═══════════════════════════════════════════════════════════════════════
META_BUSINESS_TOKEN=EAA...sua-token-aqui...XXXXX
INSTAGRAM_BUSINESS_ID=1234567890

# ═══════════════════════════════════════════════════════════════════════
# 🗄️  DATABASE
# ═══════════════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://user:password@localhost/nexuscrm
SQLALCHEMY_SILENCE_UBER_WARNING=1

# ═══════════════════════════════════════════════════════════════════════
# 🔑 API KEYS PADRÃO (Railway)
# ═══════════════════════════════════════════════════════════════════════
API_KEY=nexus_sk_prod_XXXXX
SECRET_KEY=some-secret-key-here
JWT_SECRET=jwt-secret-key-here

# ═══════════════════════════════════════════════════════════════════════
# 🌐 ENVIRONMENT
# ═══════════════════════════════════════════════════════════════════════
ENVIRONMENT=production
RAILWAY_STATIC_URL=https://api.nexuscrm.tech

# ═══════════════════════════════════════════════════════════════════════
# 📝 INSTRUÇÕES:
# ═══════════════════════════════════════════════════════════════════════
# 1. Obtenha os tokens de cada plataforma:
#    - WhatsApp: developer.facebook.com
#    - Telegram: @BotFather no Telegram
#    - SendGrid: sendgrid.com (Settings > API Keys)
#    - Meta: facebook.com/business
#
# 2. Cole os valores reais acima (substitua XXXXX)
#
# 3. Salve este arquivo como .env
#
# 4. Railway sincroniza automaticamente os valores
#
# 5. Restart o servidor: git push origin main
# ═══════════════════════════════════════════════════════════════════════
